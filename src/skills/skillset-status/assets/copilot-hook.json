{
  "version": 1,
  "hooks": {
    "userPromptSubmitted": [
      {
        "type": "command",
        "command": "skillset scan-prompt",
        "timeoutSec": 10
      }
    ],
    "preCompact": [
      {
        "type": "command",
        "command": "skillset reset --stdin-json",
        "timeoutSec": 10
      }
    ]
  }
}
